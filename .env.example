# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Neo4j connection ──────────────────────────────────────────────────────────
# MANAGED MODE (recommended): start Neo4j manually, point here.
# The app connects to your running instance — no spawning.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# EMBEDDED MODE (advanced): leave NEO4J_URI unset and set the binary path instead.
# The app will spawn a dedicated Neo4j process per KB.
# SKB_NEO4J_BIN_DIR=C:\path\to\neo4j

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Where KBs are stored on disk
# SKB_DATA_DIR=./data

# Backend API port
# SKB_API_PORT=3000

# Neo4j bolt port range (one port per KB)
# SKB_NEO4J_PORT_START=7687
# SKB_NEO4J_PORT_END=7787

# Python binary (use 'python' on Windows if 'python3' is not on PATH)
# SKB_PYTHON=python3

# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info

# Set to 'development' to enable pino-pretty coloured logs
# NODE_ENV=development
