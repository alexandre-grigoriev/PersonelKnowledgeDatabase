# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Path to your local Neo4j installation root (the folder that contains bin/, conf/, lib/)
# Windows example: C:\neo4j-community-5.x
# Mac example:     /usr/local/opt/neo4j
SKB_NEO4J_BIN_DIR=C:\path\to\neo4j

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Where KBs are stored on disk
# SKB_DATA_DIR=./data

# Backend API port
# SKB_API_PORT=3000

# Neo4j bolt port range (one port per KB)
# SKB_NEO4J_PORT_START=7687
# SKB_NEO4J_PORT_END=7787

# Python binary (use 'python' on Windows if 'python3' is not on PATH)
# SKB_PYTHON=python3

# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info

# Set to 'development' to enable pino-pretty coloured logs
# NODE_ENV=development
